# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Editor-scope token for seed scripts and server-side reads.
# Generate at https://www.sanity.io/manage → project → API → Tokens.
SANITY_API_TOKEN=
# Webhook secret to authorise /api/revalidate calls from Sanity
SANITY_REVALIDATE_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://capabilitycentre.com.au

# Email (Resend) — generate at https://resend.com/api-keys
RESEND_API_KEY=
# Optional overrides; otherwise the contact form pulls `to` from Sanity siteSettings.contactEmail
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# DO NOT use a NEXT_PUBLIC_* prefix for the service-role key.
# That prefix ships the key to every browser — anyone visiting the site gets admin access.
# If/when needed, keep it server-only as plain SUPABASE_SECRET_KEY.
# SUPABASE_SECRET_KEY=
